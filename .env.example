# ─────────────────────────────────────────────────────────────────
#  rarbtc.com NFT Bot — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to GitHub — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────

# Your rarbtc.com login username or email
RARBTC_USERNAME=your_username_or_email_here

# Your rarbtc.com login password
RARBTC_PASSWORD=your_password_here

# The reservation popup password (used on /nft/reservation)
RARBTC_RESERVATION_PASSWORD=your_reservation_password_here
