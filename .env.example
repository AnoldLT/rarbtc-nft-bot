# Rarzz NFT Bot — credential template
# Copy this file to .env and fill in your values
# NEVER commit .env — it is in .gitignore

# Number of accounts to run (1–5)
ACCOUNT_COUNT=1

# Account 1 credentials
RARBTC_USERNAME_1=your_email@example.com
RARBTC_PASSWORD_1=your_login_password
RARBTC_RESERVATION_PASSWORD_1=your_6digit_pin

# Account 2 credentials (optional — add if ACCOUNT_COUNT >= 2)
# RARBTC_USERNAME_2=
# RARBTC_PASSWORD_2=
# RARBTC_RESERVATION_PASSWORD_2=

# Account 3 credentials (optional)
# RARBTC_USERNAME_3=
# RARBTC_PASSWORD_3=
# RARBTC_RESERVATION_PASSWORD_3=

# Account 4 credentials (optional)
# RARBTC_USERNAME_4=
# RARBTC_PASSWORD_4=
# RARBTC_RESERVATION_PASSWORD_4=

# Account 5 credentials (optional)
# RARBTC_USERNAME_5=
# RARBTC_PASSWORD_5=
# RARBTC_RESERVATION_PASSWORD_5=

# SendGrid email notifications (optional — bot runs fine without these)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTIFY_EMAIL_TO=recipient@example.com
NOTIFY_EMAIL_FROM=verified_sender@example.com
